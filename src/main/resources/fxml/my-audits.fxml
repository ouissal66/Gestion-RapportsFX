<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f4f7f6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    
    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <VBox spacing="5">
            <Label text="📝 Mes Audits" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Suivez l'avancement de vos audits en temps réel." style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Nouvel Audit" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 10 20; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <!-- Table Section -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <TableView prefHeight="500" style="-fx-background-color: transparent;">
            <columns>
                <TableColumn text="Réf" prefWidth="80" style="-fx-alignment: CENTER;"/>
                <TableColumn text="Titre de l'Audit" prefWidth="300"/>
                <TableColumn text="Date Début" prefWidth="150"/>
                <TableColumn text="Score" prefWidth="100" style="-fx-alignment: CENTER;"/>
                <TableColumn text="Statut" prefWidth="150" style="-fx-alignment: CENTER;"/>
                <TableColumn text="Action" prefWidth="120" style="-fx-alignment: CENTER;"/>
            </columns>
            <placeholder>
                <Label text="Chargement de vos audits..." style="-fx-text-fill: #95a5a6;"/>
            </placeholder>
        </TableView>
    </VBox>
    
    <!-- Footer/Stats Rapides -->
    <HBox spacing="20">
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #d1f2eb; -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="✅" style="-fx-font-size: 20;"/>
            <Label text="12 Audits Terminés" style="-fx-font-weight: bold; -fx-text-fill: #16a085;"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: #fef9e7; -fx-padding: 15; -fx-background-radius: 8;" HBox.hgrow="ALWAYS">
            <Label text="⏳" style="-fx-font-size: 20;"/>
            <Label text="4 En Cours" style="-fx-font-weight: bold; -fx-text-fill: #f1c40f;"/>
        </HBox>
    </HBox>
</VBox>

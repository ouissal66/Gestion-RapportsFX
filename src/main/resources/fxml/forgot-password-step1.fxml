<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.mindjavafx.controller.ForgotPasswordController"
      style="-fx-background-color: #f5f5f5;">

    <!-- Carte principale centrée -->
    <VBox alignment="TOP_CENTER" spacing="25" maxWidth="650" 
          style="-fx-background-color: white; -fx-padding: 60 80; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 20, 0, 0, 5);">
        
        <!-- Titre principal -->
        <Label text="Mot de passe oublié ?" 
               style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
        
        <!-- Description -->
        <Label text="Veuillez saisir votre email de connexion afin de recevoir le lien de réinitialisation de votre mot de passe." 
               style="-fx-font-size: 16; -fx-text-fill: #666666; -fx-wrap-text: true; -fx-text-alignment: left; -fx-line-spacing: 4px;" 
               maxWidth="550" wrapText="true"/>
        
        <!-- Champ Email -->
        <VBox spacing="12" style="-fx-padding: 15 0 0 0;">
            <Label text="Email de connexion" 
                   style="-fx-font-size: 15; -fx-text-fill: #666666; -fx-font-weight: 500;"/>
            <TextField fx:id="contactField" promptText="Saisir votre email" 
                      style="-fx-padding: 18; -fx-font-size: 15; -fx-border-color: #0066ff; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8; -fx-background-color: white;"
                      prefWidth="550"/>
        </VBox>
        
        <!-- Captcha "Je ne suis pas un robot" avec logo reCAPTCHA -->
        <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 0; -fx-border-color: #d3d3d3; -fx-border-width: 1; -fx-border-radius: 3; -fx-background-color: #f9f9f9; -fx-background-radius: 3; -fx-pref-height: 74; -fx-pref-width: 300;">
            <VBox alignment="CENTER" style="-fx-padding: 0 20;">
                <CheckBox fx:id="captchaCheckBox" style="-fx-pref-width: 28; -fx-pref-height: 28;"/>
            </VBox>
            <Label text="Je ne suis pas un robot" style="-fx-font-size: 16; -fx-text-fill: #555555;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER" spacing="3" style="-fx-padding: 0 10 0 0;">
                <HBox spacing="0" alignment="CENTER">
                    <Label text="🔄" style="-fx-font-size: 20; -fx-text-fill: #4285f4; -fx-rotate: 90;"/>
                    <Label text="🔒" style="-fx-font-size: 16; -fx-text-fill: #999999; -fx-padding: 0 0 0 5;"/>
                </HBox>
                <Label text="reCAPTCHA" style="-fx-font-size: 10; -fx-text-fill: #555555; -fx-font-weight: bold;"/>
                <HBox spacing="3">
                    <Hyperlink text="Confidentialité" style="-fx-font-size: 8; -fx-text-fill: #1a73e8; -fx-padding: 0; -fx-underline: false;"/>
                    <Label text="-" style="-fx-font-size: 8; -fx-text-fill: #999999;"/>
                    <Hyperlink text="Conditions" style="-fx-font-size: 8; -fx-text-fill: #1a73e8; -fx-padding: 0; -fx-underline: false;"/>
                </HBox>
            </VBox>
        </HBox>
        
        <!-- Message d'erreur -->
        <Label fx:id="messageLabel" text="" 
               style="-fx-text-fill: #e74c3c; -fx-font-size: 14; -fx-wrap-text: true; -fx-font-weight: 600;"
               visible="false" managed="false"/>
        
        <!-- Bouton principal (désactivé par défaut) -->
        <Button fx:id="sendButton" text="Recevoir le lien" onAction="#handleSendCode" 
                disable="true"
                prefHeight="60" maxWidth="550"
                style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #0066ff; -fx-background-radius: 30; -fx-cursor: hand; -fx-opacity: 0.5;"/>
        
        <!-- Lien retour -->
        <Hyperlink text="retour à la page de connexion" onAction="#handleBackToLogin"
                   style="-fx-font-size: 15; -fx-text-fill: #0066ff; -fx-underline: true; -fx-padding: 10 0 0 0;"/>
        
    </VBox>

</StackPane>

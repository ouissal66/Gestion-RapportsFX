<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.RolePermissionController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">

<VBox spacing="25" style="-fx-padding: 30;">
    
    <!-- HEADER -->
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <Label text="🔐 Gestion des Rôles et Permissions" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Label text="Gérer les rôles et leurs permissions associées" style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;"/>
    </VBox>
    
    <!-- Section des rôles -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <Label text="➕ Créer un nouveau rôle" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #2c3e50;"/>
        
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Nom du rôle:" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #34495e;"/>
            <ComboBox fx:id="roleNameCombo" prefWidth="250" promptText="Sélectionner un rôle" 
                      style="-fx-font-size: 13; -fx-padding: 8;"/>
        </HBox>
        
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Description:" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #34495e;"/>
            <TextField fx:id="roleDescriptionField" prefWidth="400" promptText="Description du rôle"
                       style="-fx-font-size: 13; -fx-padding: 8;"/>
        </HBox>
        
        <Button text="✅ Créer Rôle" onAction="#handleCreateRole" 
                style="-fx-padding: 12 30; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand; -fx-background-radius: 6;"/>
    </VBox>
    
    <!-- Tableau des rôles créés -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <Label text="📋 Rôles créés" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #2c3e50;"/>
        
        <TableView fx:id="rolesTable" prefHeight="250" minHeight="200" 
                   style="-fx-font-size: 13; -fx-border-color: #ecf0f1; -fx-border-radius: 5;">
            <columns>
                <TableColumn fx:id="roleNameColumn" text="Nom du Rôle" prefWidth="200" minWidth="150" 
                            style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                <TableColumn fx:id="roleDescriptionColumn" text="Description" prefWidth="500" minWidth="300"
                            style="-fx-font-size: 13;"/>
            </columns>
        </TableView>
    </VBox>
    
    <!-- Section des permissions -->
    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <Label text="🔑 Permissions disponibles" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #2c3e50;"/>
        <Label text="Sélectionnez les permissions à gérer" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
        
        <ListView fx:id="permissionsList" prefHeight="350" minHeight="300"
                  style="-fx-font-size: 14; -fx-border-color: #ecf0f1; -fx-border-radius: 5; -fx-border-width: 2; -fx-background-color: #fafafa;"/>
        
        <HBox spacing="15">
            <Button text="➕ Ajouter Permission" onAction="#handleAddPermission" 
                    style="-fx-padding: 12 30; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand; -fx-background-radius: 6;"/>
            <Button text="🗑️ Supprimer Permission" onAction="#handleRemovePermission" 
                    style="-fx-padding: 12 30; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-cursor: hand; -fx-background-radius: 6;"/>
        </HBox>
    </VBox>
    
    <Label fx:id="messageLabel" text="" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #27ae60; -fx-padding: 10;"/>
</VBox>

</ScrollPane>
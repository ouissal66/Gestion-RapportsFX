<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.StatisticsController"
            fitToWidth="true" style="-fx-background-color: #ecf0f1;">

    <VBox spacing="30" style="-fx-padding: 30px;">
        
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Statistiques Systeme" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </HBox>
        
        <Label text="Vue d'ensemble des statistiques" style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

        <GridPane hgap="30" vgap="30">
            <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 40px;"
                  prefWidth="280" prefHeight="200" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Total Utilisateurs" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="totalUsersLabel" text="0" style="-fx-text-fill: #2c3e50; -fx-font-size: 56px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 40px;"
                  prefWidth="280" prefHeight="200" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Utilisateurs Actifs" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="activeUsersLabel" text="0" style="-fx-text-fill: #27ae60; -fx-font-size: 56px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 40px;"
                  prefWidth="280" prefHeight="200" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Utilisateurs Inactifs" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="inactiveUsersLabel" text="0" style="-fx-text-fill: #e74c3c; -fx-font-size: 56px; -fx-font-weight: bold;"/>
            </VBox>

            <VBox spacing="15" alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 40px;"
                  prefWidth="280" prefHeight="200" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <Label text="Total Audits" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label fx:id="totalAuditsLabel" text="0" style="-fx-text-fill: #3498db; -fx-font-size: 56px; -fx-font-weight: bold;"/>
            </VBox>
        </GridPane>

        <HBox spacing="30">
            <VBox spacing="20" alignment="TOP_CENTER" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 30px;"
                  prefWidth="500" HBox.hgrow="ALWAYS">
                <Label text="Repartition des Roles" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <PieChart fx:id="roleDistributionChart" prefHeight="350" animated="true" legendSide="BOTTOM"/>
                <HBox spacing="30" alignment="CENTER">
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Admin" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="adminCountLabel" text="0 (0%)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="User" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="userCountLabel" text="0 (0%)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #9b59b6;"/>
                    </VBox>
                    <VBox spacing="5" alignment="CENTER">
                        <Label text="Auditeur" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;"/>
                        <Label fx:id="auditeurCountLabel" text="0 (0%)" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 30px;"
                  prefWidth="500" HBox.hgrow="ALWAYS">
                <Label text="Moyennes des Scores" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <VBox spacing="25" style="-fx-padding: 20px 0;">
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Securite" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="securityAvgLabel" text="0/100" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                        </HBox>
                        <ProgressBar fx:id="securityAvgProgress" progress="0" prefWidth="400" prefHeight="12" style="-fx-accent: #27ae60;"/>
                    </VBox>
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Conformite" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="complianceAvgLabel" text="0/100" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                        </HBox>
                        <ProgressBar fx:id="complianceAvgProgress" progress="0" prefWidth="400" prefHeight="12" style="-fx-accent: #f39c12;"/>
                    </VBox>
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Performance" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="performanceAvgLabel" text="0/100" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                        </HBox>
                        <ProgressBar fx:id="performanceAvgProgress" progress="0" prefWidth="400" prefHeight="12" style="-fx-accent: #e67e22;"/>
                    </VBox>
                    <VBox spacing="10">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Score Global" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="globalAvgLabel" text="0/100" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                        </HBox>
                        <ProgressBar fx:id="globalAvgProgress" progress="0" prefWidth="400" prefHeight="12" style="-fx-accent: #3498db;"/>
                    </VBox>
                </VBox>
            </VBox>
        </HBox>

        <VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 30px;">
            <Label text="Activite Globale" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <ListView fx:id="globalActivityList" prefHeight="250"/>
        </VBox>

    </VBox>

</ScrollPane>
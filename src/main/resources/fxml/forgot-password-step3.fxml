<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.mindjavafx.controller.ForgotPasswordController"
      alignment="CENTER" spacing="20" style="-fx-background-color: #f0f4f8; -fx-padding: 40;">

    <VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);" maxWidth="450">
        
        <!-- Header -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="🔑" style="-fx-font-size: 48;"/>
            <Label text="Nouveau mot de passe" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Créez un nouveau mot de passe sécurisé" style="-fx-font-size: 13; -fx-text-fill: #7f8c8d; -fx-wrap-text: true; -fx-text-alignment: center;" maxWidth="350"/>
        </VBox>
        
        <!-- Form -->
        <VBox spacing="15" style="-fx-padding: 20 0;">
            <VBox spacing="8">
                <Label text="Nouveau mot de passe:" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;"/>
                <PasswordField fx:id="newPasswordField" promptText="Minimum 6 caractères" 
                          style="-fx-padding: 14; -fx-border-radius: 8; -fx-font-size: 13; -fx-border-color: #dfe6e9; -fx-border-width: 2; -fx-background-radius: 8;"/>
            </VBox>
            
            <VBox spacing="8">
                <Label text="Confirmer le mot de passe:" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Retapez le mot de passe" 
                          style="-fx-padding: 14; -fx-border-radius: 8; -fx-font-size: 13; -fx-border-color: #dfe6e9; -fx-border-width: 2; -fx-background-radius: 8;"/>
            </VBox>
            
            <Label fx:id="messageLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12; -fx-wrap-text: true; -fx-font-weight: bold;"/>
            
            <Button text="🔒 Réinitialiser le mot de passe" onAction="#handleResetPassword" prefHeight="50"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #27ae60; -fx-background-radius: 8; -fx-cursor: hand;"/>
        </VBox>
        
    </VBox>

</VBox>

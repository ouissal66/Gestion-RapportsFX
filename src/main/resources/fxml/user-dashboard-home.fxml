<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.UserDashboardHomeController"
            fitToWidth="true" style="-fx-background-color: #ecf0f1;">

    <VBox spacing="20" style="-fx-padding: 30px;">
        
        <!-- Welcome Section -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="👋 Bienvenue," style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="welcomeUserLabel" text="Utilisateur" style="-fx-font-size: 24px; -fx-text-fill: #3498db;"/>
        </HBox>
        
        <!-- Statistics Cards -->
        <GridPane hgap="20" vgap="20">
            <!-- Card 1: Score Global -->
            <VBox spacing="10" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
                  prefWidth="250" prefHeight="150" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="📊 Score Global" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <HBox alignment="BASELINE_LEFT" spacing="5">
                    <Label fx:id="globalScoreLabel" text="85" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                    <Label text="/100" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-opacity: 0.8;"/>
                </HBox>
                <Label fx:id="scoreStatusLabel" text="Excellent ✨" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Card 2: Mes Audits -->
            <VBox spacing="10" style="-fx-background-color: linear-gradient(to bottom right, #f093fb, #f5576c); -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
                  prefWidth="250" prefHeight="150" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="📝 Mes Audits" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <HBox alignment="BASELINE_LEFT" spacing="5">
                    <Label fx:id="auditCountLabel" text="12" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                    <Label text="audits" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.8;"/>
                </HBox>
                <Label text="4 ce mois-ci" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Card 3: Rapports -->
            <VBox spacing="10" style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe); -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
                  prefWidth="250" prefHeight="150" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="📄 Rapports" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <HBox alignment="BASELINE_LEFT" spacing="5">
                    <Label fx:id="reportCountLabel" text="8" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                    <Label text="PDF" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.8;"/>
                </HBox>
                <Label text="Disponibles" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            </VBox>

            <!-- Card 4: Notifications -->
            <VBox fx:id="notificationCard" spacing="10" style="-fx-background-color: linear-gradient(to bottom right, #2ecc71, #27ae60); -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 5);"
                  prefWidth="250" prefHeight="150" GridPane.columnIndex="3" GridPane.rowIndex="0">
                <Label text="🔔 Notifications" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-opacity: 0.9;"/>
                <HBox alignment="BASELINE_LEFT" spacing="5">
                    <Label fx:id="notificationCountLabel" text="3" style="-fx-text-fill: white; -fx-font-size: 48px; -fx-font-weight: bold;"/>
                    <Label text="nouvelles" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-opacity: 0.8;"/>
                </HBox>
                <Label text="Non lues" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
            </VBox>
        </GridPane>

        <!-- Charts Section -->
        <HBox spacing="20">
            <!-- Left: Bar Chart -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);"
                  HBox.hgrow="ALWAYS">
                <Label text="📊 Évolution des Scores" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <BarChart fx:id="scoreEvolutionChart" prefHeight="300" animated="true" legendVisible="false">
                    <xAxis>
                        <CategoryAxis side="BOTTOM"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" upperBound="100"/>
                    </yAxis>
                </BarChart>
            </VBox>

            <!-- Right: Pie Chart -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 20px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);"
                  prefWidth="400">
                <Label text="🎯 Répartition par Catégorie" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                <PieChart fx:id="categoryDistributionChart" prefHeight="300" animated="true" legendSide="BOTTOM"/>
            </VBox>
        </HBox>

        <!-- Category Status Indicators -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
            <Label text="📋 Résumé Rapide" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            
            <HBox spacing="30">
                <!-- Security Status -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🔒" style="-fx-font-size: 24px;"/>
                        <Label text="Sécurité" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    </HBox>
                    <ProgressBar fx:id="securityProgress" progress="0.9" prefWidth="200" prefHeight="10" 
                                style="-fx-accent: #27ae60;"/>
                    <Label fx:id="securityStatusLabel" text="Excellent (90/100)" style="-fx-text-fill: #27ae60; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Compliance Status -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="✅" style="-fx-font-size: 24px;"/>
                        <Label text="Conformité" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    </HBox>
                    <ProgressBar fx:id="complianceProgress" progress="0.75" prefWidth="200" prefHeight="10"
                                style="-fx-accent: #f39c12;"/>
                    <Label fx:id="complianceStatusLabel" text="Bon (75/100)" style="-fx-text-fill: #f39c12; -fx-font-size: 12px;"/>
                </VBox>

                <!-- Performance Status -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="⚡" style="-fx-font-size: 24px;"/>
                        <Label text="Performance" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                    </HBox>
                    <ProgressBar fx:id="performanceProgress" progress="0.65" prefWidth="200" prefHeight="10"
                                style="-fx-accent: #e74c3c;"/>
                    <Label fx:id="performanceStatusLabel" text="À améliorer (65/100)" style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Recent Activity -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
            <Label text="🕐 Dernière Activité" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            
            <ListView fx:id="recentActivityList" prefHeight="200" style="-fx-background-color: transparent; -fx-border-color: transparent;"/>
        </VBox>

        <!-- Quick Actions -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15px; -fx-padding: 25px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
            <Label text="⚡ Actions Rapides" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            
            <HBox spacing="15">
                <Button text="➕ Nouvel Audit" onAction="#handleCreateAudit"
                       style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12px 25px; -fx-background-radius: 8px; -fx-cursor: hand;"/>
                
                <Button text="📄 Générer Rapport" onAction="#handleGenerateReport"
                       style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12px 25px; -fx-background-radius: 8px; -fx-cursor: hand;"/>
                
                <Button text="📅 Planifier Audit" onAction="#handleScheduleAudit"
                       style="-fx-background-color: #1abc9c; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12px 25px; -fx-background-radius: 8px; -fx-cursor: hand;"/>
                
                <Button text="📊 Voir Analytics" onAction="#handleViewAnalytics"
                       style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 12px 25px; -fx-background-radius: 8px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

    </VBox>

</ScrollPane>

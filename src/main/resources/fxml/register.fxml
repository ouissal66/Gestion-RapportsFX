<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.RegisterController"
            fitToWidth="true" fitToHeight="true" style="-fx-background-color: #f0f4f8;">

<HBox style="-fx-background-color: #f0f4f8;">

    <!-- LEFT SIDE - ILLUSTRATION -->
    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: linear-gradient(to bottom, #27ae60, #229954); -fx-padding: 20;" prefWidth="400">
        <Label text="MindAudit" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Rejoignez-nous!" style="-fx-font-size: 11; -fx-text-fill: white; -fx-opacity: 0.9;"/>
        
        <!-- Banner Image -->
        <ImageView fitHeight="320" fitWidth="450" preserveRatio="true">
            <Image url="@../images/banner.jpg"/>
        </ImageView>
        
        <Label text="✓ Inscription rapide et sécurisée" style="-fx-text-fill: white; -fx-font-size: 10;"/>
        <Label text="✓ Accès immédiat après validation" style="-fx-text-fill: white; -fx-font-size: 10;"/>
        <Label text="✓ Interface intuitive et moderne" style="-fx-text-fill: white; -fx-font-size: 10;"/>
    </VBox>

    <!-- RIGHT SIDE - REGISTER FORM -->
    <VBox alignment="CENTER" spacing="12" style="-fx-padding: 25;" HBox.hgrow="ALWAYS">
        
        <VBox alignment="CENTER" spacing="5">
            <Label text="Créer un compte" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Remplissez le formulaire ci-dessous" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        
        <VBox spacing="12" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);" prefWidth="380">
            
            <!-- Messages -->
            <VBox spacing="5">
                <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-font-size: 11;"/>
                <Label fx:id="successLabel" text="" style="-fx-text-fill: #27ae60; -fx-font-weight: bold; -fx-font-size: 11;"/>
            </VBox>

            <!-- Form Fields -->
            <GridPane hgap="15" vgap="15">
                <Label text="Nom complet:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12;" minWidth="120"/>
                <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" promptText="Ex: Jean Dupont" prefWidth="250" style="-fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #dfe6e9; -fx-border-width: 1;"/>
                
                <Label text="Email:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12;" minWidth="120"/>
                <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="email@example.com" prefWidth="250" style="-fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #dfe6e9; -fx-border-width: 1;"/>
                
                <Label text="Mot de passe:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12;" minWidth="120"/>
                <PasswordField fx:id="passwordField" GridPane.rowIndex="2" GridPane.columnIndex="1" promptText="Min. 6 caractères" prefWidth="250" style="-fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #dfe6e9; -fx-border-width: 1;"/>
                
                <Label text="Age:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12;" minWidth="120"/>
                <TextField fx:id="ageField" GridPane.rowIndex="3" GridPane.columnIndex="1" promptText="Ex: 25" prefWidth="250" style="-fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #dfe6e9; -fx-border-width: 1;"/>
                
                <Label text="Telephone:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 12;" minWidth="120"/>
                <TextField fx:id="telephoneField" GridPane.rowIndex="4" GridPane.columnIndex="1" promptText="0612345678" prefWidth="250" style="-fx-padding: 10; -fx-border-radius: 5; -fx-border-color: #dfe6e9; -fx-border-width: 1;"/>
            </GridPane>

            <!-- Register Button -->
            <Button text="✅ S'inscrire" onAction="#handleRegister" prefWidth="400" prefHeight="45"
                   style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5;"/>

            <!-- Back to Login -->
            <HBox alignment="CENTER" spacing="5">
                <Label text="Vous avez déjà un compte?" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
                <Button text="Se connecter" onAction="#handleBackToLogin" 
                       style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-font-weight: bold; -fx-cursor: hand; -fx-underline: true; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </VBox>
</HBox>

</ScrollPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.mindjavafx.controller.ForgotPasswordController"
      alignment="CENTER" spacing="20" style="-fx-background-color: #f0f4f8; -fx-padding: 40;">

    <VBox alignment="CENTER" spacing="20" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5);" maxWidth="450">
        
        <!-- Header -->
        <VBox alignment="CENTER" spacing="10">
            <Label text="📱" style="-fx-font-size: 48;"/>
            <Label text="Code de vérification" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="sentToLabel" text="Un code a été envoyé à votre email/téléphone" style="-fx-font-size: 13; -fx-text-fill: #7f8c8d; -fx-wrap-text: true; -fx-text-alignment: center;" maxWidth="350"/>
            
            <!-- AFFICHAGE DU CODE POUR TEST -->
            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #fff3cd; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ffc107; -fx-border-width: 2; -fx-border-radius: 8;">
                <Label text="🔑 CODE DE TEST (Mode Développement)" style="-fx-font-size: 11; -fx-text-fill: #856404; -fx-font-weight: bold;"/>
                <Label fx:id="codeDisplayLabel" text="------" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #f57c00; -fx-font-family: 'Courier New';"/>
                <Label text="Copiez ce code ci-dessus" style="-fx-font-size: 10; -fx-text-fill: #856404;"/>
            </VBox>
        </VBox>
        
        <!-- Form -->
        <VBox spacing="15" style="-fx-padding: 20 0;">
            <VBox spacing="8">
                <Label text="Code de vérification (6 chiffres):" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #2c3e50;"/>
                <TextField fx:id="codeField" promptText="123456" 
                          style="-fx-padding: 14; -fx-border-radius: 8; -fx-font-size: 18; -fx-border-color: #dfe6e9; -fx-border-width: 2; -fx-background-radius: 8; -fx-alignment: center; -fx-font-weight: bold;"/>
            </VBox>
            
            <Label fx:id="messageLabel" text="" style="-fx-text-fill: #e74c3c; -fx-font-size: 12; -fx-wrap-text: true; -fx-font-weight: bold;"/>
            
            <Button text="✅ Vérifier le code" onAction="#handleVerifyCode" prefHeight="50"
                    style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #27ae60; -fx-background-radius: 8; -fx-cursor: hand;"/>
            
            <HBox alignment="CENTER" spacing="5">
                <Label text="Code non reçu?" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
                <Button text="Renvoyer le code" onAction="#handleResendCode"
                       style="-fx-background-color: transparent; -fx-text-fill: #3498db; -fx-cursor: hand; -fx-underline: true; -fx-font-size: 12; -fx-font-weight: bold;"/>
            </HBox>
            
            <Button text="← Retour" onAction="#handleBackToStep1" prefHeight="40"
                    style="-fx-font-size: 13; -fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand; -fx-border-color: #dfe6e9; -fx-border-width: 2; -fx-border-radius: 8; -fx-background-radius: 8;"/>
        </VBox>
        
    </VBox>

</VBox>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.Text?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.audit.auditaifx.controller.ClientController"
      stylesheets="@audit.css" style="-fx-background-color: #f0f2f5;">

    <!-- Sidebar: Search & List -->
    <VBox prefWidth="300" spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 1 0 0;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Mes Rapports" styleClass="form-title" HBox.hgrow="ALWAYS"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="⚙️" onAction="#switchAdmin" tooltip="${adminTooltip}" style="-fx-background-color: #f1f5f9; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
        
        <VBox spacing="5">
            <Label text="Rechercher" styleClass="form-label"/>
            <TextField fx:id="txtSearch" promptText="Titre ou auditeur..." />
        </VBox>

        <VBox spacing="5">
            <Label text="Statut" styleClass="form-label"/>
            <ComboBox fx:id="cmbFilterStatut" maxWidth="Infinity" />
        </VBox>

        <Separator/>

        <ListView fx:id="listRapports" VBox.vgrow="ALWAYS" styleClass="table-view"/>
    </VBox>

    <!-- Main Content: Details -->
    <StackPane HBox.hgrow="ALWAYS">
        <!-- Placeholder if nothing selected -->
        <VBox fx:id="lblNoSelection" alignment="CENTER" spacing="10">
            <Label text="🔍" style="-fx-font-size: 50;"/>
            <Label text="Sélectionnez un rapport pour voir les détails" style="-fx-text-fill: #7f8c8d;"/>
        </VBox>

        <!-- Details Pane -->
        <ScrollPane fx:id="detailPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 30;" visible="false">
            <VBox spacing="25">
                <VBox spacing="10">
                    <Label fx:id="lblTitre" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1a237e;"/>
                    <HBox spacing="20">
                        <Label fx:id="lblAuditeur" styleClass="footer-label"/>
                        <Label fx:id="lblDate" styleClass="footer-label"/>
                        <Label fx:id="lblStatut" styleClass="badge-en-cours" />
                    </HBox>
                </VBox>

                <VBox spacing="10" styleClass="table-view" style="-fx-padding: 20;">
                    <Label text="Description du Rapport" styleClass="section-title"/>
                    <TextArea fx:id="txtDescription" editable="false" wrapText="true" prefHeight="100" style="-fx-background-color: transparent; -fx-border-width: 0;"/>
                </VBox>

                <VBox spacing="15">
                    <Label text="Points de vigilance & Recommandations" styleClass="section-title"/>
                    <VBox fx:id="recommendationsContainer" spacing="12">
                        <!-- Reco cards will be added here via Java -->
                    </VBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </StackPane>
</HBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.*?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.audit.auditaifx.controller.MainController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header" style="-fx-padding: 15;">
        <Label styleClass="header-title" text="🔍 AuditAI — Administration" />
        <Region HBox.hgrow="ALWAYS" />
        
        <!-- Notification Icon -->
        <StackPane fx:id="paneNotifIcon" onMouseClicked="#afficherMenuNotifications" style="-fx-cursor: hand;">
            <Label style="-fx-font-size: 18;" text="🔔" />
            <Label fx:id="lblNotifCount" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 1 5; -fx-font-size: 10px; -fx-font-weight: bold;" text="0" StackPane.alignment="TOP_RIGHT" translateX="6" translateY="-4" />
        </StackPane>

        <Button onAction="#switchClient" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Vue Client" />
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <!-- SIDEBAR -->
        <VBox prefWidth="240.0" minWidth="240.0" spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label style="-fx-font-size: 14; -fx-text-fill: #bdc3c7; -fx-font-weight: bold;" text="MENU PRINCIPAL" />
            
            <Button onAction="#showDashboard" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;" text="Tableau de Bord" />
            
            <Button onAction="#showAllReports" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;" text="Liste des Rapports" />
            
            <Separator style="-fx-opacity: 0.2;" />
            
            <Button onAction="#ajouterRapport" maxWidth="Infinity" styleClass="btn-add-rapport" text="+ Nouveau Rapport" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <VBox spacing="8">
                <Button maxWidth="Infinity" onAction="#exporterExcel" styleClass="btn-excel" text="Export Excel" />
                <Button maxWidth="Infinity" onAction="#exporterPDF" styleClass="btn-pdf" text="Export PDF" />
            </VBox>
        </VBox>

        <!-- MAIN AREA -->
        <StackPane HBox.hgrow="ALWAYS">
            
            <!-- VIEW 1: DYNAMIC DASHBOARD -->
            <ScrollPane fx:id="dashboardView" fitToWidth="true" style="-fx-background-color: #f4f7f6;">
                <VBox alignment="TOP_CENTER" spacing="25" style="-fx-padding: 30;">
                    <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1a237e;" text="Tableau de Bord Analytique" />
                    
                    <FlowPane alignment="CENTER" hgap="20" vgap="20">
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Total Rapports" />
                            <Label fx:id="lblDashTotalRapports" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Recommandations" />
                            <Label fx:id="lblDashTotalReco" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Résolution" />
                            <Label fx:id="lblDashTaux" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0%" />
                        </VBox>
                    </FlowPane>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📈 Répartition par Statut" />
                            <PieChart fx:id="chartStatut" prefHeight="250" legendVisible="false" />
                        </VBox>
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📊 Priorités des Recommandations" />
                            <BarChart fx:id="chartPriorite" prefHeight="250" legendVisible="false">
                                <xAxis><CategoryAxis label="Priorité" /></xAxis>
                                <yAxis><NumberAxis label="Nombre" /></yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>

                    <!-- LIGNE 2 : TENDANCE DES CRÉATIONS -->
                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📈 Tendance des créations d'audits" />
                        <LineChart fx:id="chartTendance" prefHeight="200" legendVisible="false">
                            <xAxis><CategoryAxis label="Date" /></xAxis>
                            <yAxis><NumberAxis label="Nombre de rapports" /></yAxis>
                        </LineChart>
                    </VBox>

                    <!-- AI PRIORITY RECOMMENDATION CARD -->
                    <VBox fx:id="vboxAICard" spacing="0" style="-fx-background-color: linear-gradient(to right, #1a237e, #7b1fa2); -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(26,35,126,0.35), 12, 0, 0, 5);">
                        <!-- Header bar -->
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16 20 12 20;">
                            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" text="✨ Recommandation IA — Priorité d'Action" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnRefreshAI" onAction="#refreshAIRecommendation"
                                    style="-fx-background-color: #3949ab; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 14; -fx-cursor: hand; -fx-font-size: 12px;"
                                    text="Actualiser" />
                        </HBox>
                        <!-- Main content -->
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 0 0 15 15; -fx-padding: 18 20 18 20;">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <!-- Priority badge -->
                                <VBox alignment="CENTER" prefWidth="60" prefHeight="60"
                                      style="-fx-background-color: #fdf0f0; -fx-background-radius: 30; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 30;">
                                    <Label fx:id="lblAIPriorityBadge" style="-fx-font-size: 24; -fx-alignment: center;" text="🔴" />
                                </VBox>
                                <!-- Recommendation text -->
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="RAPPORT À TRAITER EN PREMIER" />
                                    <Label fx:id="lblAIRapportTitre" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Chargement..." wrapText="true" />
                                    <Label fx:id="lblAIRaison" style="-fx-font-size: 13; -fx-text-fill: #555; -fx-wrap-text: true;" text="" wrapText="true" />
                                </VBox>
                                <!-- Action button -->
                                <Button fx:id="btnVoirRapportAI" onAction="#voirRapportPrioritaire"
                                        style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand; -fx-font-weight: bold;"
                                        text="Voir le rapport →" />
                            </HBox>
                            <!-- Score bar -->
                            <HBox spacing="20" style="-fx-padding: 8 0 0 0;" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 11; -fx-text-fill: #95a5a6;" text="Score de priorité IA :" />
                                <ProgressBar fx:id="progressPrioriteAI" prefWidth="200" prefHeight="10" progress="0.0"
                                             style="-fx-accent: #e74c3c;" />
                                <Label fx:id="lblScoreAI" style="-fx-font-size: 11; -fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="0/100" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblAIDetail" style="-fx-font-size: 11; -fx-text-fill: #7f8c8d;" text="" wrapText="true" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🕒 Activités Récentes" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#showAllReports" style="-fx-background-color: transparent; -fx-text-fill: #3498db;" text="Voir tout →" />
                        </HBox>
                        <VBox fx:id="vboxRecentReports" spacing="10">
                            <!-- Recent items will be injected here -->
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- VIEW 2: ALL REPORTS LIST -->
            <VBox fx:id="allReportsView" spacing="10" style="-fx-background-color: #f4f7f6; -fx-padding: 20 25 20 25;" visible="false">

                <!-- Compact modern toolbar -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10 14; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">

                    <!-- Search -->
                    <TextField fx:id="txtSearchReports" prefWidth="180" prefHeight="30"
                               promptText="🔍  Rechercher..."
                               style="-fx-background-color: #f5f6fa; -fx-background-radius: 7; -fx-border-color: transparent; -fx-font-size: 12px; -fx-padding: 4 10;" />

                    <!-- Separator -->
                    <Separator orientation="VERTICAL" style="-fx-opacity: 0.3;" prefHeight="24" />

                    <!-- Par statut -->
                    <ComboBox fx:id="comboFilterStatut" prefWidth="130" prefHeight="30"
                              promptText="Statut"
                              styleClass="combo-filter" />

                    <!-- Par nom (auditeur) -->
                    <ComboBox fx:id="comboFilterNom" prefWidth="140" prefHeight="30"
                              promptText="Auditeur"
                              styleClass="combo-filter" />

                    <Button onAction="#resetFilters" styleClass="btn-reset" text="Initialiser" />

                    <Region HBox.hgrow="ALWAYS" />

                    <!-- New rapport button -->
                    <Button onAction="#creerNouveauRapport"
                            style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-background-radius: 7; -fx-padding: 5 14; -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;"
                            text="+ Nouveau" />
                </HBox>

                <TableView fx:id="rapportsTable" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-radius: 10;">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTitre" prefWidth="240" text="Titre" />
                        <TableColumn fx:id="colEntite" prefWidth="120" text="Entité" />
                        <TableColumn fx:id="colAuditeur" prefWidth="120" text="Auditeur" />
                        <TableColumn fx:id="colStatut" prefWidth="90" text="Statut" />
                        <TableColumn fx:id="colDate" prefWidth="90" text="Date" />
                        <TableColumn fx:id="colNbReco" prefWidth="60" text="Recos" />
                        <TableColumn fx:id="colActionsRapport" prefWidth="120" text="Actions" />
                    </columns>
                </TableView>

                <!-- Compact pagination bar -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 2 0 0 0;">
                    <Button fx:id="btnPrevPage" onAction="#pagePrev"
                            style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 3 12; -fx-font-size: 11px; -fx-cursor: hand;"
                            text="‹ Préc" />
                    <Label fx:id="lblPageInfo" style="-fx-font-size: 12px; -fx-text-fill: #2c3e50; -fx-font-weight: bold;" text="1 / 1" />
                    <Button fx:id="btnNextPage" onAction="#pageNext"
                            style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 3 12; -fx-font-size: 11px; -fx-cursor: hand;"
                            text="Suiv ›" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalFiltered" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="" />
                </HBox>
            </VBox>


            <!-- VIEW 3: REPORT DETAILS -->
            <ScrollPane fx:id="detailView" fitToWidth="true" style="-fx-background-color: #f4f7f6; -fx-background: #f4f7f6; -fx-border-color: transparent;" visible="false">
                <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: #f4f7f6;">

                    <!-- TOP BAR: Back + Action buttons -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button onAction="#showAllReports" style="-fx-background-color: #bdc3c7; -fx-text-fill: white; -fx-background-radius: 6; -fx-padding: 6 14; -fx-cursor: hand;" text="← Retour" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#modifierRapportSelectionne" styleClass="btn-edit" text="Modifier" />
                        <Button onAction="#supprimerRapportSelectionne" styleClass="btn-delete" text="Supprimer" />
                        <Button onAction="#genererRecoIA" fx:id="btnAnalyserIA" styleClass="btn-ai" text="✨ Recos IA" />
                        <Button onAction="#calculerScoreAudit" fx:id="btnDetecterRisques" styleClass="btn-ai" text="📊 Score Rapport" />
                        <Button onAction="#genererRisquesIA" styleClass="btn-risk" text="⚠️ Détecter Risques" />
                        <Label fx:id="lblScoreBadge" styleClass="score-badge" visible="false" managed="false" />
                    </HBox>

                <!-- INFO CARD: All report details vertical -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 18 20; -fx-border-color: #e8eaf6; -fx-border-width: 1; -fx-border-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 6, 0, 0, 2);">

                    <!-- Titre + Badge statut -->
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label fx:id="lblSelectedTitre" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a237e;" text="Titre du Rapport" wrapText="true" HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblStatutBadge" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 3 12; -fx-font-size: 11px; -fx-font-weight: bold;" text="STATUT" />
                    </HBox>

                    <Separator style="-fx-opacity: 0.4;" />

                    <!-- Méta-données: 2 colonnes -->
                    <HBox spacing="40">
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-min-width: 80;" text="Entité :" />
                                <Label fx:id="lblInfoEntite" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="" />
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-min-width: 80;" text="Auditeur :" />
                                <Label fx:id="lblInfoAuditeur" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="" />
                            </HBox>
                        </VBox>
                        <VBox spacing="6">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-min-width: 90;" text="Créé le :" />
                                <Label fx:id="lblDateCreation" style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;" text="" />
                            </HBox>
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-min-width: 90;" text="Mis à jour :" />
                                <Label fx:id="lblSelectedSub" style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;" text="" />
                            </HBox>
                        </VBox>
                    </HBox>

                    <Separator style="-fx-opacity: 0.4;" />

                    <!-- Description -->
                    <VBox spacing="4">
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="DESCRIPTION" />
                        <Label fx:id="txtDescriptionRapport" wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #34495e; -fx-line-spacing: 3;" text="" />
                    </VBox>

                    <Separator style="-fx-opacity: 0.4;" />

                    <!-- Score de résolution -->
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="SCORE DE RÉSOLUTION" />
                            <Label fx:id="lblScoreResolution" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0%" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblRecoStats" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" text="0 / 0 résolues" />
                        </HBox>
                        <ProgressBar fx:id="progressResolution" prefWidth="99999" prefHeight="12" progress="0.0"
                                     style="-fx-accent: #27ae60;" />
                    </VBox>
                </VBox>


                <!-- RECOMMANDATIONS SECTION -->
                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="📌 Recommandations et Suivi" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnAjouterReco" onAction="#ajouterRecommandation" styleClass="btn-add-reco" text="+ Ajouter" />
                    </HBox>
                    <TableView fx:id="recoTable" prefHeight="350" minHeight="250">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colRecoDesc" prefWidth="300" text="Description" />
                            <TableColumn fx:id="colRecoPriorite" prefWidth="100" text="Priorité" />
                            <TableColumn fx:id="colRecoResolue" prefWidth="100" text="Résolue" />
                            <TableColumn fx:id="colActionsReco" prefWidth="180" text="Actions" />
                        </columns>
                    </TableView>
                </VBox>

                <!-- RISQUES SECTION -->
                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #c0392b;" text="⚠ Risques Détectés" />
                        <Label fx:id="lblRisqueCount" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 2 8; -fx-font-size: 11px; -fx-font-weight: bold;" text="0" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>
                    <TableView fx:id="risqueTable" prefHeight="250" minHeight="150">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colRisqueAlerte" prefWidth="50" text="!" />
                            <TableColumn fx:id="colRisqueNiveau" prefWidth="100" text="Niveau" />
                            <TableColumn fx:id="colRisqueDesc" prefWidth="330" text="Description" />
                            <TableColumn fx:id="colRisqueImpact" prefWidth="230" text="Impact" />
                            <TableColumn fx:id="colActionsRisque" prefWidth="100" text="Actions" />
                        </columns>
                    </TableView>
                </VBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </HBox>

    <!-- FOOTER -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="footer" style="-fx-padding: 10 20;">
        <Label fx:id="lblTotalRapports" styleClass="footer-label" text="0 rapport(s)" />
        <Label fx:id="lblTotalReco" styleClass="footer-label" text="0 recommandation(s)" />
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="AuditAI Admin Analytics v3.0" />
    </HBox>

</VBox>
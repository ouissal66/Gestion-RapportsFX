<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.audit.auditaifx.controller.MainController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header">
        <Label styleClass="header-title" text="🔍 AuditAI — Administration" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#switchClient" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="👤 Vue Client" />
    </HBox>

    <!-- SECTION RAPPORTS -->
    <VBox prefHeight="460.0" prefWidth="897.0" spacing="8" style="-fx-padding: 15 20 10 20;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label prefHeight="17.0" prefWidth="275.0" styleClass="section-title" text="📋 Rapports d'Audit" />
            <Region prefHeight="14.0" prefWidth="619.0" HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAjouterRapport" onAction="#ajouterRapport" prefHeight="25.0" prefWidth="317.0" styleClass="btn-add-rapport" text="+ Ajouter Rapport" />
        </HBox>

        <TableView fx:id="rapportsTable" prefHeight="396.0" prefWidth="857.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colTitre" prefWidth="167.0" text="Titre" />
                <TableColumn fx:id="colAuditeur" prefWidth="173.0" text="Auditeur" />
                <TableColumn fx:id="colEntite" prefWidth="140" text="Entité Auditée" />
                <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
                <TableColumn fx:id="colDate" prefWidth="110" text="Date Création" />
                <TableColumn fx:id="colNbReco" prefWidth="55" text="Reco." />
                <TableColumn fx:id="colActionsRapport" prefWidth="110" text="Actions" />
            </columns>
        </TableView>
    </VBox>

    <Separator prefHeight="0.0" prefWidth="897.0" styleClass="separator" />

    <!-- SECTION RECOMMANDATIONS -->
    <VBox prefHeight="423.0" prefWidth="897.0" spacing="8" style="-fx-padding: 10 20 15 20;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" prefHeight="17.0" prefWidth="857.0" spacing="10">
            <Label fx:id="lblRecommandations" prefHeight="17.0" prefWidth="596.0" styleClass="section-title" text="📌 Recommandations — sélectionnez un rapport" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnAjouterReco" disable="true" onAction="#ajouterRecommandation" prefHeight="25.0" prefWidth="281.0" styleClass="btn-add-reco" text="+ Ajouter Recommandation" />
        </HBox>

        <TableView fx:id="recoTable" prefHeight="365.0" prefWidth="673.0" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colRecoDesc" prefWidth="269.0" text="Description" />
                <TableColumn fx:id="colRecoPriorite" prefWidth="181.0" text="Priorité" />
                <TableColumn fx:id="colRecoResolue" prefWidth="138.0" text="Résolue" />
                <TableColumn fx:id="colActionsReco" prefWidth="267.0" text="Actions" />
            </columns>
        </TableView>
    </VBox>

    <!-- FOOTER -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="footer">
        <Label fx:id="lblTotalRapports" styleClass="footer-label" text="0 rapport(s)" />
        <Label fx:id="lblTotalReco" styleClass="footer-label" text="0 recommandation(s)" />
    </HBox>

</VBox>

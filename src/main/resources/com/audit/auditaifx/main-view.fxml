<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.audit.auditaifx.controller.MainController"
      spacing="10">

    <!-- HEADER -->
    <HBox styleClass="header" alignment="CENTER_LEFT" spacing="15">
        <Label text="🔍 AuditAI — Gestion des Rapports"
               styleClass="header-title"/>
    </HBox>

    <!-- SECTION RAPPORTS -->
    <VBox spacing="8" style="-fx-padding: 15 20 10 20;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="📋 Rapports d'Audit" styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAjouterRapport"
                    text="+ Ajouter Rapport"
                    styleClass="btn-add-rapport"
                    onAction="#ajouterRapport"/>
        </HBox>

        <TableView fx:id="rapportsTable" prefHeight="250">
            <columns>
                <TableColumn fx:id="colTitre"         text="Titre"          prefWidth="200"/>
                <TableColumn fx:id="colAuditeur"      text="Auditeur"       prefWidth="140"/>
                <TableColumn fx:id="colEntite"        text="Entité Auditée" prefWidth="140"/>
                <TableColumn fx:id="colStatut"        text="Statut"         prefWidth="100"/>
                <TableColumn fx:id="colDate"          text="Date Création"  prefWidth="110"/>
                <TableColumn fx:id="colNbReco"        text="Reco."          prefWidth="55"/>
                <TableColumn fx:id="colActionsRapport" text="Actions"       prefWidth="110"/>
            </columns>
        </TableView>
    </VBox>

    <Separator styleClass="separator"/>

    <!-- SECTION RECOMMANDATIONS -->
    <VBox spacing="8" VBox.vgrow="ALWAYS"
          style="-fx-padding: 10 20 15 20;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblRecommandations"
                   text="📌 Recommandations — sélectionnez un rapport"
                   styleClass="section-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAjouterReco"
                    text="+ Ajouter Recommandation"
                    styleClass="btn-add-reco"
                    onAction="#ajouterRecommandation"
                    disable="true"/>
        </HBox>

        <TableView fx:id="recoTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colRecoDesc"     text="Description" prefWidth="350"/>
                <TableColumn fx:id="colRecoPriorite" text="Priorité"    prefWidth="100"/>
                <TableColumn fx:id="colRecoResolue"  text="Résolue"     prefWidth="80"/>
                <TableColumn fx:id="colActionsReco"  text="Actions"     prefWidth="110"/>
            </columns>
        </TableView>
    </VBox>

    <!-- FOOTER -->
    <HBox styleClass="footer" alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="lblTotalRapports" text="0 rapport(s)" styleClass="footer-label"/>
        <Label fx:id="lblTotalReco"     text="0 recommandation(s)" styleClass="footer-label"/>
    </HBox>

</VBox>
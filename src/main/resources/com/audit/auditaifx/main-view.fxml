<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.net.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.audit.auditaifx.controller.MainController"
      spacing="10" style="-fx-background-color: #f8fafc;">
    <stylesheets>
        <URL value="@css/style.css" />
    </stylesheets>

    <!-- HEADER -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 15 25 15 25;"
          alignment="CENTER_LEFT" spacing="15">
        <Label text="🔍 AuditAI — Gestion des Rapports"
               style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
    </HBox>

    <!-- SECTION RAPPORTS -->
    <VBox spacing="8" style="-fx-padding: 15 20 10 20;">

        <!-- Titre + Bouton Ajouter -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="📋 Rapports d'Audit"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAjouterRapport" text="+ Ajouter Rapport"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                    onAction="#ajouterRapport"/>
        </HBox>

        <!-- TableView Rapports -->
        <TableView fx:id="rapportsTable"
                   prefHeight="250"
                   style="-fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colTitre"    text="Titre"          prefWidth="200"/>
                <TableColumn fx:id="colAuditeur" text="Auditeur"       prefWidth="140"/>
                <TableColumn fx:id="colEntite"   text="Entité Auditée" prefWidth="140"/>
                <TableColumn fx:id="colStatut"   text="Statut"         prefWidth="100"/>
                <TableColumn fx:id="colDate"     text="Date Création"  prefWidth="110"/>
                <TableColumn fx:id="colNbReco"   text="Reco."          prefWidth="55"/>
                <TableColumn fx:id="colActionsRapport" text="Actions"  prefWidth="100"/>
            </columns>
        </TableView>

    </VBox>

    <!-- SEPARATEUR -->
    <Separator style="-fx-padding: 0 20 0 20;"/>

    <!-- SECTION RECOMMANDATIONS -->
    <VBox spacing="8" VBox.vgrow="ALWAYS"
          style="-fx-padding: 10 20 15 20;">

        <!-- Titre + Bouton Ajouter -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblRecommandations"
                   text="📌 Recommandations — sélectionnez un rapport"
                   style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAjouterReco" text="+ Ajouter Recommandation"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"
                    onAction="#ajouterRecommandation"
                    disable="true"/>
        </HBox>

        <!-- TableView Recommandations -->
        <TableView fx:id="recoTable" VBox.vgrow="ALWAYS"
                   style="-fx-background-radius: 8;">
            <columns>
                <TableColumn fx:id="colRecoDesc"     text="Description"  prefWidth="350"/>
                <TableColumn fx:id="colRecoPriorite" text="Priorité"     prefWidth="100"/>
                <TableColumn fx:id="colRecoResolue"  text="Résolue"      prefWidth="80"/>
                <TableColumn fx:id="colActionsReco"  text="Actions"      prefWidth="100"/>
            </columns>
        </TableView>

    </VBox>

    <!-- FOOTER -->
    <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 8 20 8 20;"
          alignment="CENTER_LEFT" spacing="20">
        <Label fx:id="lblTotalRapports" text="0 rapport(s)"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
        <Label fx:id="lblTotalReco" text="0 recommandation(s)"
               style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"/>
    </HBox>

</VBox>
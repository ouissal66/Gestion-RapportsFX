<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.*?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.audit.auditaifx.controller.MainController">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header" style="-fx-padding: 15;">
        <Label styleClass="header-title" text="🔍 AuditAI — Administration" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#switchClient" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Vue Client" />
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <!-- SIDEBAR -->
        <VBox prefWidth="240.0" spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <Label style="-fx-font-size: 14; -fx-text-fill: #bdc3c7; -fx-font-weight: bold;" text="MENU PRINCIPAL" />
            
            <Button onAction="#showDashboard" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;" text="Tableau de Bord" />
            
            <Button onAction="#showAllReports" maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 14; -fx-cursor: hand;" text="Liste des Rapports" />
            
            <Separator style="-fx-opacity: 0.2;" />
            
            <Button onAction="#ajouterRapport" maxWidth="Infinity" styleClass="btn-add-rapport" text="+ Nouveau Rapport" />
            
            <Region VBox.vgrow="ALWAYS" />
            
            <VBox spacing="8">
                <Button maxWidth="Infinity" onAction="#exporterExcel" styleClass="btn-excel" text="Export Excel" />
                <Button maxWidth="Infinity" onAction="#exporterPDF" styleClass="btn-pdf" text="Export PDF" />
            </VBox>
        </VBox>

        <!-- MAIN AREA -->
        <StackPane HBox.hgrow="ALWAYS">
            
            <!-- VIEW 1: DYNAMIC DASHBOARD -->
            <ScrollPane fx:id="dashboardView" fitToWidth="true" style="-fx-background-color: #f4f7f6;">
                <VBox alignment="TOP_CENTER" spacing="25" style="-fx-padding: 30;">
                    <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1a237e;" text="Tableau de Bord Analytique" />
                    
                    <FlowPane alignment="CENTER" hgap="20" vgap="20">
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Total Rapports" />
                            <Label fx:id="lblDashTotalRapports" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Recommandations" />
                            <Label fx:id="lblDashTotalReco" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Résolution" />
                            <Label fx:id="lblDashTaux" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0%" />
                        </VBox>
                    </FlowPane>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📈 Répartition par Statut" />
                            <PieChart fx:id="chartStatut" prefHeight="250" legendVisible="false" />
                        </VBox>
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📊 Priorités des Recommandations" />
                            <BarChart fx:id="chartPriorite" prefHeight="250" legendVisible="false">
                                <xAxis><CategoryAxis label="Priorité" /></xAxis>
                                <yAxis><NumberAxis label="Nombre" /></yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <HBox alignment="CENTER_LEFT">
                            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🕒 Activités Récentes" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button onAction="#showAllReports" style="-fx-background-color: transparent; -fx-text-fill: #3498db;" text="Voir tout →" />
                        </HBox>
                        <VBox fx:id="vboxRecentReports" spacing="10">
                            <!-- Recent items will be injected here -->
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- VIEW 2: ALL REPORTS LIST -->
            <VBox fx:id="allReportsView" spacing="20" style="-fx-background-color: #f4f7f6; -fx-padding: 25;" visible="false">
                <HBox alignment="CENTER_LEFT">
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📂 Tous les Rapports d'Audit" />
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtSearchReports" prefWidth="250" promptText="Rechercher un rapport..." style="-fx-background-radius: 15;" />
                </HBox>
                
                <TableView fx:id="rapportsTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTitre" prefWidth="250" text="Titre" />
                        <TableColumn fx:id="colEntite" prefWidth="150" text="Entité" />
                        <TableColumn fx:id="colAuditeur" prefWidth="150" text="Auditeur" />
                        <TableColumn fx:id="colStatut" prefWidth="100" text="Statut" />
                        <TableColumn fx:id="colDate" prefWidth="120" text="Date" />
                        <TableColumn fx:id="colNbReco" prefWidth="80" text="Recos" />
                        <TableColumn fx:id="colActionsRapport" prefWidth="120" text="Actions" />
                    </columns>
                </TableView>
            </VBox>

            <!-- VIEW 3: REPORT DETAILS -->
            <VBox fx:id="detailView" spacing="20" style="-fx-background-color: #f4f7f6; -fx-padding: 25;" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Button onAction="#showAllReports" style="-fx-background-color: #bdc3c7; -fx-text-fill: white;" text="← Retour" />
                    <VBox HBox.hgrow="ALWAYS">
                        <Label fx:id="lblSelectedTitre" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Titre du Rapport" />
                        <Label fx:id="lblSelectedSub" style="-fx-text-fill: #7f8c8d;" text="Entité - Auditeur" />
                    </VBox>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button onAction="#modifierRapportSelectionne" styleClass="btn-edit" text="Modifier" />
                        <Button onAction="#supprimerRapportSelectionne" styleClass="btn-delete" text="Supprimer" />
                        <Button onAction="#genererRecoIA" fx:id="btnAnalyserIA" styleClass="btn-ai" text="Recos (IA)" />
                        <Button onAction="#genererRisquesIA" fx:id="btnDetecterRisques" style="-fx-background-color: #e67e22;" styleClass="btn-ai" text="Risques (IA)" />
                    </HBox>
                </HBox>

                <Separator />

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT">
                        <Label styleClass="section-title" text="📌 Recommandations et Suivi" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnAjouterReco" onAction="#ajouterRecommandation" styleClass="btn-add-reco" text="+ Ajouter" />
                    </HBox>
                    
                    <TableView fx:id="recoTable" VBox.vgrow="ALWAYS">
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colRecoDesc" prefWidth="300" text="Description" />
                            <TableColumn fx:id="colRecoPriorite" prefWidth="100" text="Priorité" />
                            <TableColumn fx:id="colRecoResolue" prefWidth="100" text="Résolue" />
                            <TableColumn fx:id="colActionsReco" prefWidth="180" text="Actions" />
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </StackPane>
    </HBox>

    <!-- FOOTER -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="footer" style="-fx-padding: 10 20;">
        <Label fx:id="lblTotalRapports" styleClass="footer-label" text="0 rapport(s)" />
        <Label fx:id="lblTotalReco" styleClass="footer-label" text="0 recommandation(s)" />
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="AuditAI Admin Analytics v3.0" />
    </HBox>

</VBox>
